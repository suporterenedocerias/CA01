SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
# Chave secreta FastSoft / Fluxxopay (sk_...) — só servidor; Basic Auth base64("x:" + sk)
# Docs: https://developers.fastsoftbrasil.com/docs/intro/getting-started
FASTSOFT_SECRET_KEY=sua_chave_secreta_sk_aqui
# Opcional: chave pública (pk_...) — hoje o PIX é criado só no servidor; guarde para futuro/checkout no browser
# FASTSOFT_PUBLIC_KEY=pk_...
# URL completa do webhook que a FastSoft chama (HTTPS público). Se vazio, usa Supabase Edge ou localhost.
# Ex.: https://seudominio.com/api/fastsoft-webhook
# FASTSOFT_POSTBACK_URL=
PORT=3001
